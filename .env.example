# Server settings:
PORT="8080"

# Database settings:
# Path to the local sqlite file. It holds both the data and the search index.
DB_CONN_STR=./data/db.db

# Redis settings
REDIS_CONN_STR=localhost:6379
REDIS_PREFIX="PREFIX"

JOB_KEY="0000"

# LLM (OpenRouter)
LLM_API_KEY="your-openrouter-api-key"

# Environment
APP_ENV=development # or production

COOKIE_SECRET="secret"